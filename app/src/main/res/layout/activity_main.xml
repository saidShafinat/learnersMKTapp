<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8F7FF"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Logo -->
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="170dp"
            android:layout_height="170dp"
            android:layout_marginTop="35dp"
            android:src="@drawable/learnlogo"
            android:contentDescription="Logo"/>

        <!-- App Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Learners Marketplace"
            android:textColor="#2E2E48"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginTop="10dp"/>

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buy • Sell • Connect"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#6C63FF"
            android:layout_marginTop="8dp"/>

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="The easiest way for students to buy, sell and exchange books, electronics, stationery and much more around campus."
            android:textAlignment="center"
            android:textColor="#7A7A92"
            android:textSize="16sp"
            android:layout_marginTop="18dp"
            android:lineSpacingExtra="5dp"/>

        <!-- Create Account Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/signupbtn"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="40dp"
            android:text="Create Account"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#6C63FF"
            app:cornerRadius="30dp"/>

        <!-- Sign In Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/signinbtn"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="18dp"
            android:text="Sign In"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#6C63FF"
            app:cornerRadius="30dp"
            app:strokeWidth="2dp"
            app:strokeColor="#6C63FF"
            android:backgroundTint="@android:color/white"/>

        <!-- Divider -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="──────── Browse Categories ────────"
            android:textColor="#B0B0C3"
            android:layout_marginTop="40dp"/>

        <!-- Categories -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="25dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📚 Books"
                android:textSize="17sp"
                android:padding="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💻 Electronics"
                android:textSize="17sp"
                android:padding="10dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✏️ Stationery"
                android:textSize="17sp"
                android:padding="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎒 More"
                android:textSize="17sp"
                android:padding="10dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>